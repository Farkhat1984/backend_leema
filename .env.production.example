# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# ВАЖНО: Скопируйте этот файл в .env.production и заполните реальные значения!
# НЕ КОММИТЬТЕ .env.production в Git!

# ============================================
# APP SETTINGS
# ============================================
APP_NAME=Fashion AI Platform
APP_VERSION=1.0.0
DEBUG=false

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Формат: postgresql+asyncpg://user:password@host:port/database
# В Docker Compose: host=postgres (имя сервиса)
DATABASE_URL=postgresql+asyncpg://fashionuser:YOUR_SECURE_PASSWORD@postgres:5432/fashion_platform

# PostgreSQL credentials (для docker-compose.yml)
POSTGRES_USER=fashionuser
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=fashion_platform

# ============================================
# SECURITY
# ============================================
# Сгенерируйте секретный ключ: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=YOUR_SUPER_SECRET_KEY_CHANGE_THIS_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# GOOGLE OAUTH
# ============================================
# Получите credentials на: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# ВАЖНО: Обновите redirect URI в Google Console!
GOOGLE_REDIRECT_URI=https://api.leema.kz/api/v1/auth/google/callback

# ============================================
# GOOGLE GEMINI AI
# ============================================
# Получите API key на: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================
# PAYPAL
# ============================================
# Переключите на "live" для production!
PAYPAL_MODE=live
# Получите credentials на: https://developer.paypal.com/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# ============================================
# EMAIL (SMTP)
# ============================================
# Для Gmail нужен App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Fashion AI Platform

# ============================================
# URLS (ОБНОВЛЕНО ДЛЯ PRODUCTION!)
# ============================================
# Frontend URL для редиректов и CORS
FRONTEND_URL=https://www.leema.kz

# CORS Origins (добавьте все нужные домены)
CORS_ORIGINS=["https://www.leema.kz", "https://leema.kz", "https://api.leema.kz"]

# ============================================
# FILE UPLOADS
# ============================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760
# Allowed extensions (JSON array as string)

# ============================================
# PLATFORM SETTINGS (Defaults)
# ============================================
DEFAULT_USER_GENERATION_PRICE=1.0
DEFAULT_USER_TRY_ON_PRICE=0.5
DEFAULT_USER_FREE_GENERATIONS=3
DEFAULT_USER_FREE_TRY_ONS=5
DEFAULT_SHOP_PRODUCT_RENT_PRICE=10.0
DEFAULT_SHOP_MIN_RENT_MONTHS=1
DEFAULT_SHOP_COMMISSION_RATE=10.0
DEFAULT_REFUND_PERIOD_DAYS=14

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60/minute
